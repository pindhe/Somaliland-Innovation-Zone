# SIZSR - Apache configuration

# ---------------------------------------------------------------------------
# Security headers
# ---------------------------------------------------------------------------
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
    Header set X-XSS-Protection "1; mode=block"
</IfModule>

# ---------------------------------------------------------------------------
# Disable directory listing
# ---------------------------------------------------------------------------
Options -Indexes

# ---------------------------------------------------------------------------
# Protect sensitive files & folders
# ---------------------------------------------------------------------------
<FilesMatch "\.(sql|md|log)$">
    Require all denied
</FilesMatch>

RedirectMatch 403 (?i)/(config|includes|database)/.*$

# Block direct execution of uploaded PHP files
# (handled by assets/uploads/.htaccess — <Directory> is not allowed here)

# ---------------------------------------------------------------------------
# SEO-friendly URL rewriting -> route everything through index.php
# ---------------------------------------------------------------------------
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Detect base (project lives in /Somaliland-innovation under htdocs)
    RewriteBase /Somaliland-innovation/

    # Let real files/folders (assets, admin, api) be served directly
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Route the rest through the front controller
    RewriteRule ^(.*)$ index.php?route=$1 [QSA,L]
</IfModule>

# ---------------------------------------------------------------------------
# Compression & caching
# ---------------------------------------------------------------------------
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json
</IfModule>

<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpeg "access plus 1 month"
    ExpiresByType image/png "access plus 1 month"
    ExpiresByType image/webp "access plus 1 month"
    ExpiresByType text/css "access plus 1 week"
    ExpiresByType application/javascript "access plus 1 week"
</IfModule>
