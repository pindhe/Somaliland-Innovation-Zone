# ---------------------------------------------------------------------------
# SIZSR environment configuration
# Copy this file to ".env" and fill in your real values.
# The .env file is loaded automatically by config/config.php and should NEVER
# be committed to version control.
# ---------------------------------------------------------------------------

# WhatsApp Cloud API (Meta / Facebook Graph API)
# Get these from https://developers.facebook.com -> Your App -> WhatsApp -> API Setup
WHATSAPP_ENABLED=true
WHATSAPP_API_VERSION=v21.0
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here
WHATSAPP_TOKEN=your_permanent_access_token_here

# Default country calling code used to normalise local numbers (no +).
# Example: 252 for Somaliland/Somalia.
WHATSAPP_DEFAULT_COUNTRY_CODE=252
